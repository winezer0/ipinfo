# iplocate 配置文件
# 数据库路径支持绝对路径和相对路径（相对于可执行文件所在目录）

# ==================== ASN数据库配置 ====================
# ASN数据库用于查询IP所属的自治系统信息

# 通用ASN数据库（同时支持IPv4和IPv6）
# 当专用的 asn_ipv4_db 或 asn_ipv6_db 未配置时，将使用此数据库
asn_ipvx_db: ""

# IPv4专用ASN数据库
# 优先级高于 asn_ipvx_db
asn_ipv4_db: ""

# IPv6专用ASN数据库
# 优先级高于 asn_ipvx_db
asn_ipv6_db: ""

# ==================== IP地理位置数据库配置 ====================
# IP地理位置数据库用于查询IP的物理位置信息

# 通用IP地理位置数据库（同时支持IPv4和IPv6）
# 当专用的 ipv4_locate_db 或 ipv6_locate_db 未配置时，将使用此数据库
ipvx_locate_db: ""

# IPv4专用IP地理位置数据库
# 优先级高于 ipvx_locate_db
ipv4_locate_db: ""

# IPv6专用IP地理位置数据库
# 优先级高于 ipvx_locate_db
ipv6_locate_db: ""

# ==================== 支持的数据库格式 ====================
# ASN数据库支持格式:
#   - .mmdb (MaxMind DB格式，如 GeoLite2-ASN.mmdb)
#   - .csv  (CSV格式，如 GeoLite2-ASN-Blocks-IPv4.csv)
#
# IP地理位置数据库支持格式:
#   - .xdb  (IP2Region格式)
#   - .mmdb (MaxMind DB格式，如 GeoLite2-City.mmdb, DBIP-City.mmdb)
#   - .ipdb (IPIP.net格式)
#   - .db   (纯真数据库格式)
#   - .dat  (纯真数据库格式，如 qqwry.dat)

# ==================== 配置示例 ====================
# 示例1: 使用纯真数据库查询IPv4，ZXWry查询IPv6
# asn_ipvx_db: "assets/GeoLite2-ASN.mmdb"
# ipv4_locate_db: "assets/qqwry.dat"
# ipv6_locate_db: "assets/zxipv6wry.db"
#
# 示例2: 使用通用数据库同时支持IPv4和IPv6
# asn_ipvx_db: "assets/GeoLite2-ASN.mmdb"
# ipvx_locate_db: "assets/GeoLite2-City.mmdb"
#
# 示例3: 使用IP2Region数据库
# ipv4_locate_db: "assets/ip2region.xdb"
#
# 示例4: 使用IPIP.net数据库
# ipv4_locate_db: "assets/ipip.ipdb"
